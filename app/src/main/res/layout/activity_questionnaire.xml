<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tell us about yourself"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#E6720C"
            android:layout_marginBottom="16dp"/>

        <!-- Education Level -->
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="What is your highest level of education?"
            android:textSize="16sp"
            android:textColor="#E6720C"/>

        <Spinner
            android:id="@+id/spinnerEducation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <!-- Further Education -->
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Do you plan to pursue further education?"
            android:textSize="16sp"
            android:textColor="#E6720C"/>

        <Spinner
            android:id="@+id/spinnerFurtherEducation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <!-- Field of Study -->
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="What is your field of study?"
            android:textSize="16sp"
            android:textColor="#E6720C"/>

        <EditText
            android:id="@+id/etFieldOfStudy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Example: Computer Science"
            android:background="@android:drawable/edit_text"
            android:textColor="#000000"
            android:layout_marginBottom="12dp"/>

        <!-- Career Goals -->
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="What is your career goal?"
            android:textSize="16sp"
            android:textColor="#E6720C"/>

        <EditText
            android:id="@+id/etCareerGoal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Example: Become a Data Scientist"
            android:background="@android:drawable/edit_text"
            android:textColor="#000000"
            android:layout_marginBottom="12dp"/>

        <!-- Work Type -->
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="What kind of work do you prefer?"
            android:textSize="16sp"
            android:textColor="#E6720C"/>

        <Spinner
            android:id="@+id/spinnerWorkType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <!-- Areas to Master -->
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Which skills do you want to master?"
            android:textSize="16sp"
            android:textColor="#E6720C"/>

        <EditText
            android:id="@+id/etSkillsToMaster"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Example: Machine Learning, Web Development"
            android:background="@android:drawable/edit_text"
            android:textColor="#000000"
            android:layout_marginBottom="12dp"/>

        <!-- Submit Button -->
        <Button
            android:id="@+id/btnSubmitQuestionnaire"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Submit"
            android:background="@drawable/button_rounded"
            android:textColor="#FFFFFF"
            android:layout_marginTop="16dp"/>

    </LinearLayout>
</ScrollView>
